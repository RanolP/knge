  },
  "devDependencies": {
    "@react-router/dev": "^7.8.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "oxfmt": "^0.34.0",
    "oxlint": "^0.17.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
